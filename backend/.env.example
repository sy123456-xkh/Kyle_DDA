# Chat-to-BI MVP 后端环境变量

# LLM 配置（OpenAI-compatible，支持 Claude/DeepSeek/其他）
# 不填写 LLM_API_KEY 时，系统自动使用 mock 洞察（不阻断流程）
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-xxx
LLM_MODEL=deepseek-chat

# 如需接入 Anthropic Claude（OpenAI 兼容端点）：
# LLM_BASE_URL=https://api.anthropic.com/v1
# LLM_API_KEY=sk-ant-xxx
# LLM_MODEL=claude-3-5-haiku-20241022
